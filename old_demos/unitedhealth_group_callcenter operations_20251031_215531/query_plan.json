{
  "datasets": [
    {
      "name": "call_center_transactions",
      "type": "timeseries",
      "required_fields": {
        "transaction_id": "keyword",
        "@timestamp": "date",
        "agent_id": "keyword",
        "member_id": "keyword",
        "call_type": "keyword",
        "call_duration_seconds": "integer",
        "resolution_status": "keyword",
        "verification_steps_count": "integer",
        "processing_time_seconds": "integer",
        "transaction_cost": "float",
        "call_notes": "text",
        "denial_code": "keyword",
        "prior_auth_id": "keyword"
      },
      "relationships": [
        "agents",
        "member_plans",
        "prior_authorizations",
        "provider_network"
      ],
      "semantic_fields": [
        "call_notes"
      ]
    },
    {
      "name": "agents",
      "type": "reference",
      "required_fields": {
        "agent_id": "keyword",
        "agent_name": "text",
        "team": "keyword",
        "hire_date": "date",
        "specialization": "keyword",
        "efficiency_rating": "float"
      },
      "relationships": [
        "call_center_transactions"
      ],
      "semantic_fields": []
    },
    {
      "name": "member_plans",
      "type": "reference",
      "required_fields": {
        "member_id": "keyword",
        "plan_type": "keyword",
        "plan_name": "text",
        "coverage_tier": "keyword",
        "eligibility_status": "keyword",
        "effective_date": "date",
        "deductible_remaining": "float",
        "out_of_pocket_max": "float"
      },
      "relationships": [
        "call_center_transactions"
      ],
      "semantic_fields": []
    },
    {
      "name": "prior_authorizations",
      "type": "reference",
      "required_fields": {
        "prior_auth_id": "keyword",
        "member_id": "keyword",
        "medication_name": "text",
        "status": "keyword",
        "submission_date": "date",
        "days_pending": "integer",
        "provider_id": "keyword",
        "urgency_flag": "boolean"
      },
      "relationships": [
        "call_center_transactions",
        "provider_network"
      ],
      "semantic_fields": []
    },
    {
      "name": "provider_network",
      "type": "reference",
      "required_fields": {
        "provider_id": "keyword",
        "provider_name": "text",
        "specialty": "keyword",
        "network_status": "keyword",
        "last_verified_date": "date",
        "accepting_patients": "boolean",
        "address": "text",
        "phone": "keyword"
      },
      "relationships": [
        "prior_authorizations"
      ],
      "semantic_fields": []
    },
    {
      "name": "insurance_knowledge_base",
      "type": "reference",
      "required_fields": {
        "article_id": "keyword",
        "title": "text",
        "content": "text",
        "category": "keyword",
        "topic_tags": "keyword",
        "last_updated": "date",
        "view_count": "integer"
      },
      "relationships": [],
      "semantic_fields": [
        "title",
        "content"
      ]
    },
    {
      "name": "claims_denials",
      "type": "reference",
      "required_fields": {
        "denial_code": "keyword",
        "denial_reason": "text",
        "common_resolution": "text",
        "appeal_success_rate": "float",
        "category": "keyword"
      },
      "relationships": [
        "call_center_transactions"
      ],
      "semantic_fields": [
        "denial_reason",
        "common_resolution"
      ]
    }
  ],
  "query_plans": [
    {
      "name": "Verification Friction Analysis",
      "query_type": "scripted",
      "pain_point": "Multiple verification steps for security causing friction",
      "required_datasets": [
        "call_center_transactions",
        "agents"
      ],
      "required_fields": {
        "call_center_transactions": [
          "@timestamp",
          "transaction_id",
          "agent_id",
          "verification_steps_count",
          "call_duration_seconds",
          "processing_time_seconds"
        ],
        "agents": [
          "agent_id",
          "agent_name",
          "team"
        ]
      },
      "description": "Analyze correlation between verification steps and call duration over last 30 days. Use INLINESTATS to compare each transaction against team averages, identify outliers where excessive verification causes delays. Use LOOKUP JOIN to enrich with agent details."
    },
    {
      "name": "Prior Authorization Bottleneck Detection",
      "query_type": "scripted",
      "pain_point": "Urgent medication needs and delays in provider submissions",
      "required_datasets": [
        "prior_authorizations",
        "provider_network",
        "call_center_transactions"
      ],
      "required_fields": {
        "prior_authorizations": [
          "prior_auth_id",
          "member_id",
          "status",
          "days_pending",
          "urgency_flag",
          "provider_id",
          "submission_date"
        ],
        "provider_network": [
          "provider_id",
          "provider_name",
          "specialty",
          "network_status"
        ],
        "call_center_transactions": [
          "prior_auth_id",
          "call_type"
        ]
      },
      "description": "Identify urgent prior authorizations pending over 3 days. Use LOOKUP JOIN to enrich with provider details and network status. Use CHANGE_POINT to detect sudden spikes in pending authorizations by provider or specialty. Calculate call volume related to each pending auth."
    },
    {
      "name": "Cost Efficiency Anomaly Detection",
      "query_type": "scripted",
      "pain_point": "Need to optimize cost per transaction and processing time",
      "required_datasets": [
        "call_center_transactions",
        "agents",
        "member_plans"
      ],
      "required_fields": {
        "call_center_transactions": [
          "@timestamp",
          "transaction_id",
          "agent_id",
          "member_id",
          "call_type",
          "transaction_cost",
          "processing_time_seconds",
          "resolution_status"
        ],
        "agents": [
          "agent_id",
          "agent_name",
          "team",
          "efficiency_rating"
        ],
        "member_plans": [
          "member_id",
          "plan_type",
          "coverage_tier"
        ]
      },
      "description": "Use FORK to create parallel analysis: (1) cost per transaction by call type, (2) processing time trends by agent team, (3) efficiency rate by plan complexity. Use INLINESTATS to flag transactions 2x above average cost. Use LOOKUP JOIN for agent and plan enrichment."
    },
    {
      "name": "Find Members by Plan and Coverage Status",
      "query_type": "parameterized",
      "pain_point": "Coverage and benefits verification - pulling member plan details and eligibility",
      "required_datasets": [
        "member_plans",
        "call_center_transactions"
      ],
      "required_fields": {
        "member_plans": [
          "member_id",
          "plan_type",
          "plan_name",
          "coverage_tier",
          "eligibility_status",
          "deductible_remaining",
          "out_of_pocket_max"
        ],
        "call_center_transactions": [
          "member_id",
          "transaction_id",
          "call_type",
          "@timestamp"
        ]
      },
      "description": "Interactive tool to search members by ?plan_type and ?eligibility_status. Use LOOKUP JOIN to show recent call history. Use INLINESTATS to show each member's call volume vs plan type average. Return member details with coverage information for quick verification."
    },
    {
      "name": "Provider Network Search and Verification",
      "query_type": "parameterized",
      "pain_point": "Network directories not always being current",
      "required_datasets": [
        "provider_network",
        "prior_authorizations"
      ],
      "required_fields": {
        "provider_network": [
          "provider_id",
          "provider_name",
          "specialty",
          "network_status",
          "last_verified_date",
          "accepting_patients",
          "address",
          "phone"
        ],
        "prior_authorizations": [
          "provider_id",
          "status",
          "submission_date"
        ]
      },
      "description": "Search providers by ?specialty and ?network_status. Flag providers with last_verified_date > 90 days as potentially outdated. Use LOOKUP JOIN to show pending prior auth counts per provider. Calculate days since last verification to prioritize directory updates."
    },
    {
      "name": "Claims Denial Code Lookup and Resolution",
      "query_type": "parameterized",
      "pain_point": "Claims issues and denials - accessing claim status and explaining denial codes",
      "required_datasets": [
        "claims_denials",
        "call_center_transactions"
      ],
      "required_fields": {
        "claims_denials": [
          "denial_code",
          "denial_reason",
          "common_resolution",
          "appeal_success_rate",
          "category"
        ],
        "call_center_transactions": [
          "denial_code",
          "transaction_id",
          "@timestamp",
          "resolution_status"
        ]
      },
      "description": "Interactive tool to lookup denial information by ?denial_code. Use LOOKUP JOIN to enrich transaction data with denial explanations. Show appeal success rates and common resolutions. Use STATS to show frequency of each denial code in last 90 days."
    },
    {
      "name": "Insurance Terminology and Policy Explanation",
      "query_type": "rag",
      "pain_point": "Plans vary significantly and customers don't understand insurance terminology",
      "required_datasets": [
        "insurance_knowledge_base"
      ],
      "required_fields": {
        "insurance_knowledge_base": [
          "article_id",
          "title",
          "content",
          "category",
          "topic_tags",
          "last_updated"
        ]
      },
      "description": "Semantic search knowledge base using ?customer_question. Use MATCH on title and content fields to find relevant articles explaining insurance terms, plan differences, and coverage details. RERANK by relevance to question. Use COMPLETION to generate plain-language summary suitable for customer explanation."
    }
  ]
}