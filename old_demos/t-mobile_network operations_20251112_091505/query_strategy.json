          "hss_node",
          "sync_failure",
          "sqn_failure",
          "diameter_result_code"
        ],
        "hss_node_reference": [
          "hss_node",
          "hss_cluster",
          "datacenter",
          "database_type",
          "replication_mode"
        ]
      },
      "join_chain": [
        "hss_authentication_events -> hss_node_reference"
      ],
      "description": "Identify mass authentication failure events by aggregating failed authentication attempts per 5-minute interval (minimum 200 failures), enriched with HSS node details to pinpoint database corruption, synchronization issues, or replication failures affecting subscriber authentication across specific HSS clusters",
      "complexity": "medium"
    },
