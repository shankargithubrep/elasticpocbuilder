# Vulcan - Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.

# =============================================================================
# LLM Configuration (at least one required)
# =============================================================================

# Anthropic API (Recommended)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: LLM Proxy (OpenAI-compatible, for centralized model management)
# LLM_PROXY_URL=https://your-proxy-url/v1
# LLM_PROXY_API_KEY=your-proxy-api-key

# Optional: OpenAI API (fallback, limited ES|QL support)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override default LLM model
# LLM_DEFAULT_MODEL=claude-sonnet-4-5-20250929

# =============================================================================
# Elasticsearch (Required for data indexing and query testing)
# =============================================================================

# Cloud ID + API Key (Elastic Cloud)
ELASTICSEARCH_CLOUD_ID=your-deployment-name:base64encodedstring
ELASTICSEARCH_API_KEY=your-api-key-here

# Alternative: Direct endpoint
# ELASTIC_ENDPOINT=https://your-cluster.es.region.cloud.es.io:443
# ELASTIC_API_KEY=your-api-key-here

# =============================================================================
# Kibana (Required for Agent Builder deployment)
# =============================================================================
ELASTICSEARCH_KIBANA_URL=https://your-deployment.kb.region.cloud.es.io:443

# =============================================================================
# Optional
# =============================================================================
# LOG_LEVEL=INFO
# DEMO_OUTPUT_DIR=./demos

# =============================================================================
# Multi-Region Setup (for data residency scenarios)
# Pattern: ES_URL_<TAG>, ES_API_KEY_<TAG>, KIBANA_URL_<TAG>
# TAG = region identifier in UPPER_SNAKE_CASE (e.g. US_EAST_1, EU_WEST_1)
# Vulcan auto-detects these and builds a MultiRegionElasticClient.
# You can also configure regions via Settings → Multi-Region in the UI.
# =============================================================================

# US Region (AWS us-east-1)
# ES_URL_US_EAST_1=https://genesys-us.es.us-east-1.aws.elastic.cloud:443
# ES_API_KEY_US_EAST_1=your-us-api-key
# KIBANA_URL_US_EAST_1=https://genesys-us.kb.us-east-1.aws.elastic.cloud:443

# EU Region (AWS eu-west-1) — data stays in Europe
# ES_URL_EU_WEST_1=https://genesys-eu.es.eu-west-1.aws.elastic.cloud:443
# ES_API_KEY_EU_WEST_1=your-eu-api-key
# KIBANA_URL_EU_WEST_1=https://genesys-eu.kb.eu-west-1.aws.elastic.cloud:443

# APAC Region (AWS ap-southeast-1)
# ES_URL_AP_SOUTHEAST_1=https://genesys-ap.es.ap-southeast-1.aws.elastic.cloud:443
# ES_API_KEY_AP_SOUTHEAST_1=your-ap-api-key
# KIBANA_URL_AP_SOUTHEAST_1=https://genesys-ap.kb.ap-southeast-1.aws.elastic.cloud:443
