# Elastic Demo Builder Configuration
# Copy this file to .env and fill in your actual values

# ===================================
# REQUIRED: Elasticsearch Configuration
# ===================================
# Provide EITHER Cloud ID OR Host (not both)

# Option 1: Elastic Cloud (recommended)
ELASTICSEARCH_CLOUD_ID=your_cloud_id_here
ELASTICSEARCH_API_KEY=your_api_key_here
ELASTICSEARCH_KIBANA_URL=https://your-deployment.kb.region.cloud.es.io

# Option 2: Self-managed Elasticsearch
# ELASTICSEARCH_HOST=localhost:9200
# ELASTICSEARCH_API_KEY=your_api_key_here

# ===================================
# REQUIRED: LLM Configuration
# ===================================
# Anthropic API key for Claude (required for demo generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI API key for GPT models
# OPENAI_API_KEY=your_openai_api_key_here

# ===================================
# OPTIONAL: GitHub Configuration
# ===================================
# For state persistence and collaboration features
# GITHUB_TOKEN=your_github_token_here
# GITHUB_REPO=your-org/your-repo
# GITHUB_BRANCH=main

# ===================================
# OPTIONAL: Web Search Configuration
# ===================================
# For customer research and context enrichment
# SERP_API_KEY=your_serp_api_key_here

# ===================================
# Demo Generation Defaults
# ===================================
DEFAULT_REGION=us-west-2
DEFAULT_INDEX_PREFIX=demo_
DEFAULT_DATA_SIZE=medium  # Options: small, medium, large

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=demo_builder.log

# ===================================
# Feature Flags
# ===================================
ENABLE_VALIDATION=true
ENABLE_GITHUB_PERSISTENCE=false
ENABLE_WEB_SEARCH=false
ENABLE_AUTO_DEPLOY=false

# ===================================
# Resource Limits
# ===================================
MAX_QUERY_COUNT=20
MAX_DATA_ROWS=50000
VALIDATION_TIMEOUT_SECONDS=30