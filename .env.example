# Elastic Demo Builder Configuration
# Copy this file to .env and fill in your values

# Elasticsearch Configuration
ELASTICSEARCH_HOST=localhost:9200
ELASTICSEARCH_API_KEY=your_api_key_here
ELASTICSEARCH_CLOUD_ID=your_cloud_id_here  # Optional: for Elastic Cloud

# LLM Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional: for GPT models

# GitHub Configuration (for state persistence)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=elastic/demo-builder
GITHUB_BRANCH=main

# Web Search Configuration (optional)
SERP_API_KEY=your_serp_api_key_here  # For customer research

# Demo Defaults
DEFAULT_REGION=us-west-2
DEFAULT_INDEX_PREFIX=demo_
DEFAULT_DATA_SIZE=medium  # small, medium, large

# Logging
LOG_LEVEL=INFO
LOG_FILE=demo_builder.log

# Feature Flags
ENABLE_VALIDATION=true
ENABLE_GITHUB_PERSISTENCE=true
ENABLE_WEB_SEARCH=false
ENABLE_AUTO_DEPLOY=false

# Resource Limits
MAX_QUERY_COUNT=20
MAX_DATA_ROWS=50000
VALIDATION_TIMEOUT_SECONDS=30